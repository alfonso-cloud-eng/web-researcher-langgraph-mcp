# LLM via OpenRouter (OpenAI-compatible)
LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_ID=google/gemma-4-31b-it:free

# Path to the compiled MCP server (after running npm run build)
MCP_SERVER_PATH=./mcp_browser_server/dist/index.js

# Max navigation steps before the agent gives up
MAX_LOOPS=20
